@startuml
top to bottom direction

title Autonomous Inventory Drone for Pallet Location Verification\n System Architecture

package "Simulation Layer" {
  component "Webots Environment" as Webots
  component "Drone Controller" as DroneController
}

package "Perception Layer" {
  component "Barcode Detection Module" as BarcodeCV
}

package "Frontend Layer" {
  component "Dashboard UI" as Frontend
}

package "Backend Layer" {
  component "FastAPI Backend API" as API
  component "Scan Processing Service" as ScanService
  component "Report Export Service" as ExportService
  component "Authentication Service" as AuthService
}

package "Data Layer" {
  database "SQLite Database" as DB
}

Webots --> DroneController
DroneController --> BarcodeCV : camera frames\n

BarcodeCV --> API : HTTP POST /scans\n201 Created (JSON)

Frontend --> API : HTTP GET /scans\n200 OK (JSON)
Frontend --> API : HTTP GET /reports/export\n200 OK (XLSX/csv)
Frontend --> API : HTTP POST /auth/login\n200 OK (JWT)

API --> ScanService : reconciliation logic
API --> ExportService : generate report
API --> AuthService : authenticate user

ScanService --> DB : store + retrieve scan records
ExportService --> DB : retrieve scan records
AuthService --> DB : verify user credentials

@enduml